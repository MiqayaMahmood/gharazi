NODE_ENV=development
APP_NAME=gharazi-pk

# API
API_PORT=3001
WORKER_CONCURRENCY=5
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,

# Data services
# Supabase is used only as hosted PostgreSQL. Prisma connects through DATABASE_URL.
DATABASE_URL=<Supabase PostgreSQL connection string>
# Optional. Use only if Prisma migrations require a direct Supabase connection string.
DIRECT_URL=<optional Supabase direct connection string for migrations>
# Local Redis: redis://localhost:6379
# Upstash Redis over TLS: rediss://default:<password>@<upstash-host>:6379
REDIS_URL=rediss://default:<password>@<upstash-host>:6379
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=Gharazi
SEARCH_ENABLED=true
SEARCH_DB_FALLBACK_ENABLED=true

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=Gharazi-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# API safety
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120

# Auth
JWT_SECRET=replace-with-a-long-random-secret-for-local-development
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
OTP_DEV_CODE=123456

# Public URLs
APP_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=false

# WordPress blog source
NEXT_PUBLIC_WP_API_BASE=https://mydaytogo.com/wp-json/wp/v2
WP_API_BASE=https://mydaytogo.com/wp-json/wp/v2
WP_MAIN_CATEGORY_SLUG="sweetnsavour"
WP_API_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=Gharazi <no-reply@Gharazi.pk>

# Media storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=
CLOUDFRONT_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_UPLOAD_MAX_MB=50

# Seeded admin
SEED_ADMIN_EMAIL=mahmoodrf@gmail.com
SEED_ADMIN_PASSWORD=replace-before-shared-use
