{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "paths": {
      "@Gharazi/shared-config": ["packages/shared-config/src"],
      "@Gharazi/shared-events": ["packages/shared-events/src"],
      "@Gharazi/shared-events/*": ["packages/shared-events/src/*"],
      "@Gharazi/shared-types": ["packages/shared-types/src"],
      "@Gharazi/shared-utils": ["packages/shared-utils/src"],
      "@Gharazi/shared-utils/*": ["packages/shared-utils/src/*"]
    }
  }
}
