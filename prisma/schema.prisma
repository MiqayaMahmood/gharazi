generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phoneNumber                  String                 @unique @map("phone_number") @db.VarChar(32)
  email                        String?                @unique @db.VarChar(255)
  phoneVerifiedAt              DateTime?              @map("phone_verified_at") @db.Timestamptz(6)
  status                       UserStatus             @default(ACTIVE)
  createdAt                    DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  emailVerifiedAt              DateTime?              @map("email_verified_at") @db.Timestamptz(6)
  passwordHash                 String?                @map("password_hash") @db.VarChar(255)
  adminNotes                   AdminNote[]            @relation("AdminNoteAuthor")
  analyticsEvents              AnalyticsEvent[]
  auditLogs                    AuditLog[]             @relation("AuditActor")
  blogPosts                    BlogPost[]             @relation("BlogPostAuthor")
  sentMessages                 ChatMessage[]          @relation("ChatMessageSender")
  chatParticipants             ChatParticipant[]
  initiatedChats               Chat[]                 @relation("ChatInitiator")
  receivedChats                Chat[]                 @relation("ChatRecipient")
  cmsPages                     CmsPage[]              @relation("CmsPageCreator")
  ownedDevelopers              Developer?             @relation("DeveloperOwner")
  favorites                    Favorite[]
  assignedInboundSubmissions   InboundSubmission[]    @relation("InboundSubmissionAssignee")
  inboundSubmissions           InboundSubmission[]    @relation("InboundSubmissionUser")
  buyerInquiries               Inquiry[]              @relation("InquiryBuyer")
  receivedInquiries            Inquiry[]              @relation("InquiryRecipient")
  listingStatuses              ListingStatusHistory[] @relation("ListingStatusChangedBy")
  managedListings              Listing[]              @relation("ListingManager")
  ownedListings                Listing[]              @relation("ListingOwner")
  moderationActions            ModerationAction[]
  notifications                Notification[]
  passwordResetTokens          PasswordResetToken[]
  paymentAttempts              PaymentAttempt[]
  paymentTransactions          PaymentTransaction[]
  projectUpdates               ProjectUpdate[]        @relation("ProjectUpdateCreator")
  purchasedPromotions          Promotion[]            @relation("PromotionPurchaser")
  reportsAssigned              Report[]               @relation("ReportAssignee")
  reportsMade                  Report[]               @relation("ReportReporter")
  riskFlagsCreated             RiskFlag[]             @relation("RiskFlagCreator")
  savedSearches                SavedSearch[]
  sessions                     Session[]
  profile                      UserProfile?
  roles                        UserRole[]
  subscriptions                UserSubscription[]
  systemEvents                 SystemEvent[]
  reviewedVerificationRequests VerificationRequest[]  @relation("VerificationReviewer")
  verificationRequests         VerificationRequest[]  @relation("VerificationRequester")

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @unique @db.VarChar(64)
  description String?    @db.VarChar(255)
  isSystem    Boolean    @default(true) @map("is_system")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  code        String     @unique @db.VarChar(64)
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserProfile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  fullName          String?  @map("full_name") @db.VarChar(120)
  avatarUrl         String?  @map("avatar_url") @db.VarChar(500)
  bio               String?  @db.VarChar(500)
  preferredLanguage String   @default("en") @map("preferred_language") @db.VarChar(8)
  whatsappNumber    String?  @map("whatsapp_number") @db.VarChar(32)
  companyName       String?  @map("company_name") @db.VarChar(160)
  websiteUrl        String?  @map("website_url") @db.VarChar(500)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model City {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(120)
  slug          String        @unique @db.VarChar(140)
  province      String?       @db.VarChar(120)
  isActive      Boolean       @default(true) @map("is_active")
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  areas         Area[]
  listings      Listing[]
  projects      Project[]
  savedSearches SavedSearch[]

  @@index([isActive, sortOrder])
  @@map("cities")
}

model Area {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId        String        @map("city_id") @db.Uuid
  name          String        @db.VarChar(160)
  slug          String        @db.VarChar(180)
  isActive      Boolean       @default(true) @map("is_active")
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  parentAreaId  String?       @map("parent_area_id") @db.Uuid
  areaLevel     String?       @map("area_level") @db.VarChar(32)
  city          City          @relation(fields: [cityId], references: [id])
  parentArea    Area?         @relation("AreaHierarchy", fields: [parentAreaId], references: [id])
  childAreas    Area[]        @relation("AreaHierarchy")
  listings      Listing[]
  projects      Project[]
  savedSearches SavedSearch[]

  @@unique([cityId, slug])
  @@index([cityId, isActive, sortOrder])
  @@index([parentAreaId])
  @@map("areas")
}

model PropertyType {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(120)
  slug          String        @unique @db.VarChar(140)
  category      String        @db.VarChar(80)
  isActive      Boolean       @default(true) @map("is_active")
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  code          String        @unique @db.VarChar(64)
  listings      Listing[]
  projectUnits  ProjectUnit[]
  projects      Project[]     @relation("ProjectType")
  savedSearches SavedSearch[]

  @@index([category, isActive, sortOrder])
  @@map("property_types")
}

model ListingPurpose {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(80)
  slug          String        @unique @db.VarChar(100)
  isActive      Boolean       @default(true) @map("is_active")
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  code          String        @unique @db.VarChar(64)
  listings      Listing[]
  savedSearches SavedSearch[]

  @@index([isActive, sortOrder])
  @@map("listing_purposes")
}

model AmenityDefinition {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String           @db.VarChar(120)
  slug             String           @unique @db.VarChar(140)
  category         String           @db.VarChar(80)
  isActive         Boolean          @default(true) @map("is_active")
  sortOrder        Int              @default(0) @map("sort_order")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  code             String           @unique @db.VarChar(64)
  listingAmenities ListingAmenity[]
  projectAmenities ProjectAmenity[]

  @@index([category, isActive, sortOrder])
  @@map("amenity_definitions")
}

model Developer {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId        String    @unique @map("owner_user_id") @db.Uuid
  companyName        String    @map("company_name") @db.VarChar(160)
  slug               String    @unique @db.VarChar(180)
  registrationNumber String?   @map("registration_number") @db.VarChar(120)
  verificationStatus String    @default("unverified") @map("verification_status") @db.VarChar(32)
  logoUrl            String?   @map("logo_url") @db.VarChar(500)
  websiteUrl         String?   @map("website_url") @db.VarChar(500)
  officeAddress      String?   @map("office_address") @db.VarChar(500)
  supportPhone       String?   @map("support_phone") @db.VarChar(32)
  description        String?   @db.VarChar(2000)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  ownerUser          User      @relation("DeveloperOwner", fields: [ownerUserId], references: [id])
  projects           Project[]

  @@index([verificationStatus])
  @@map("developers")
}

model Listing {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId           String                 @unique @map("public_id") @db.VarChar(32)
  ownerUserId        String                 @map("owner_user_id") @db.Uuid
  managedByUserId    String?                @map("managed_by_user_id") @db.Uuid
  purposeId          String                 @map("purpose_id") @db.Uuid
  propertyTypeId     String                 @map("property_type_id") @db.Uuid
  cityId             String                 @map("city_id") @db.Uuid
  areaId             String                 @map("area_id") @db.Uuid
  title              String                 @db.VarChar(180)
  description        String                 @db.VarChar(5000)
  priceAmount        Decimal                @map("price_amount") @db.Decimal(14, 2)
  priceCurrency      String                 @default("PKR") @map("price_currency") @db.VarChar(3)
  areaValue          Decimal                @map("area_value") @db.Decimal(12, 2)
  areaUnit           String                 @map("area_unit") @db.VarChar(32)
  bedrooms           Int?
  bathrooms          Int?
  floorNumber        Int?                   @map("floor_number")
  totalFloors        Int?                   @map("total_floors")
  yearBuilt          Int?                   @map("year_built")
  furnishedStatus    String?                @map("furnished_status") @db.VarChar(32)
  possessionStatus   String?                @map("possession_status") @db.VarChar(32)
  latitude           Decimal?               @db.Decimal(9, 6)
  longitude          Decimal?               @db.Decimal(9, 6)
  locationPrecision  String                 @default("approximate") @map("location_precision") @db.VarChar(32)
  addressLine        String?                @map("address_line") @db.VarChar(500)
  contactName        String?                @map("contact_name") @db.VarChar(120)
  contactPhone       String?                @map("contact_phone") @db.VarChar(32)
  contactWhatsapp    String?                @map("contact_whatsapp") @db.VarChar(32)
  sourceUrl          String?                @map("source_url") @db.VarChar(1000)
  status             String                 @default("draft") @db.VarChar(32)
  verificationStatus String                 @default("unverified") @map("verification_status") @db.VarChar(32)
  isFeatured         Boolean                @default(false) @map("is_featured")
  isHot              Boolean                @default(false) @map("is_hot")
  qualityScore       Int                    @default(0) @map("quality_score")
  viewCount          Int                    @default(0) @map("view_count")
  inquiryCount       Int                    @default(0) @map("inquiry_count")
  publishedAt        DateTime?              @map("published_at") @db.Timestamptz(6)
  expiresAt          DateTime?              @map("expires_at") @db.Timestamptz(6)
  lastRefreshedAt    DateTime?              @map("last_refreshed_at") @db.Timestamptz(6)
  deletedAt          DateTime?              @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  chats              Chat[]
  matchedDuplicates  DuplicateCandidate[]   @relation("DuplicateMatch")
  sourceDuplicates   DuplicateCandidate[]   @relation("DuplicateSource")
  inquiries          Inquiry[]
  amenities          ListingAmenity[]
  dailyStats         ListingDailyStat[]
  media              ListingMedia[]
  statusHistory      ListingStatusHistory[]
  area               Area                   @relation(fields: [areaId], references: [id])
  city               City                   @relation(fields: [cityId], references: [id])
  managedByUser      User?                  @relation("ListingManager", fields: [managedByUserId], references: [id])
  ownerUser          User                   @relation("ListingOwner", fields: [ownerUserId], references: [id])
  propertyType       PropertyType           @relation(fields: [propertyTypeId], references: [id])
  purpose            ListingPurpose         @relation(fields: [purposeId], references: [id])

  @@index([ownerUserId, status])
  @@index([status, publishedAt])
  @@index([cityId, areaId, status])
  @@index([purposeId, propertyTypeId])
  @@index([latitude, longitude])
  @@map("listings")
}

model ListingMedia {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId  String   @map("listing_id") @db.Uuid
  mediaType  String   @map("media_type") @db.VarChar(32)
  storageKey String   @map("storage_key") @db.VarChar(500)
  url        String   @db.VarChar(1000)
  sortOrder  Int      @default(0) @map("sort_order")
  width      Int?
  height     Int?
  isCover    Boolean  @default(false) @map("is_cover")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
  @@map("listing_media")
}

model ListingAmenity {
  listingId String            @map("listing_id") @db.Uuid
  amenityId String            @map("amenity_id") @db.Uuid
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  amenity   AmenityDefinition @relation(fields: [amenityId], references: [id])
  listing   Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([listingId, amenityId])
  @@index([amenityId])
  @@map("listing_amenities")
}

model ListingStatusHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId       String   @map("listing_id") @db.Uuid
  fromStatus      String?  @map("from_status") @db.VarChar(32)
  toStatus        String   @map("to_status") @db.VarChar(32)
  reason          String?  @db.VarChar(500)
  changedByUserId String?  @map("changed_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  changedByUser   User?    @relation("ListingStatusChangedBy", fields: [changedByUserId], references: [id])
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@map("listing_status_history")
}

model Project {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId             String             @unique @map("public_id") @db.VarChar(32)
  developerId          String             @map("developer_id") @db.Uuid
  cityId               String             @map("city_id") @db.Uuid
  areaId               String             @map("area_id") @db.Uuid
  projectTypeId        String             @map("project_type_id") @db.Uuid
  name                 String             @db.VarChar(180)
  slug                 String             @unique @db.VarChar(220)
  shortDescription     String?            @map("short_description") @db.VarChar(500)
  description          String             @db.VarChar(5000)
  possessionStatus     String             @map("possession_status") @db.VarChar(32)
  legalStatus          String?            @map("legal_status") @db.VarChar(80)
  expectedHandoverDate DateTime?          @map("expected_handover_date") @db.Date
  launchDate           DateTime?          @map("launch_date") @db.Date
  latitude             Decimal?           @db.Decimal(9, 6)
  longitude            Decimal?           @db.Decimal(9, 6)
  addressLine          String?            @map("address_line") @db.VarChar(500)
  brochureUrl          String?            @map("brochure_url") @db.VarChar(500)
  paymentPlanSummary   String?            @map("payment_plan_summary") @db.VarChar(2000)
  minPriceAmount       Decimal?           @map("min_price_amount") @db.Decimal(14, 2)
  maxPriceAmount       Decimal?           @map("max_price_amount") @db.Decimal(14, 2)
  verificationStatus   String             @default("unverified") @map("verification_status") @db.VarChar(32)
  status               String             @default("draft") @db.VarChar(32)
  isFeatured           Boolean            @default(false) @map("is_featured")
  publishedAt          DateTime?          @map("published_at") @db.Timestamptz(6)
  deletedAt            DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  chats                Chat[]
  inquiries            Inquiry[]
  amenities            ProjectAmenity[]
  dailyStats           ProjectDailyStat[]
  media                ProjectMedia[]
  units                ProjectUnit[]
  updates              ProjectUpdate[]
  area                 Area               @relation(fields: [areaId], references: [id])
  city                 City               @relation(fields: [cityId], references: [id])
  developer            Developer          @relation(fields: [developerId], references: [id])
  projectType          PropertyType       @relation("ProjectType", fields: [projectTypeId], references: [id])

  @@index([developerId, status])
  @@index([status, publishedAt])
  @@index([cityId, areaId, status])
  @@index([latitude, longitude])
  @@map("projects")
}

model Favorite {
  userId     String   @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(32)
  entityId   String   @map("entity_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("favorites")
}

model SavedSearch {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  name            String          @db.VarChar(120)
  purposeId       String?         @map("purpose_id") @db.Uuid
  propertyTypeId  String?         @map("property_type_id") @db.Uuid
  cityId          String?         @map("city_id") @db.Uuid
  areaId          String?         @map("area_id") @db.Uuid
  filtersJson     Json            @default("{}") @map("filters_json")
  alertEnabled    Boolean         @default(false) @map("alert_enabled")
  lastAlertSentAt DateTime?       @map("last_alert_sent_at") @db.Timestamptz(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  area            Area?           @relation(fields: [areaId], references: [id])
  city            City?           @relation(fields: [cityId], references: [id])
  propertyType    PropertyType?   @relation(fields: [propertyTypeId], references: [id])
  purpose         ListingPurpose? @relation(fields: [purposeId], references: [id])
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, alertEnabled])
  @@map("saved_searches")
}

model Notification {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  notificationType String                 @map("notification_type") @db.VarChar(64)
  title            String                 @db.VarChar(180)
  body             String?                @db.VarChar(1000)
  payloadJson      Json?                  @map("payload_json")
  readAt           DateTime?              @map("read_at") @db.Timestamptz(6)
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  deliveries       NotificationDelivery[]
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificationId   String       @map("notification_id") @db.Uuid
  channel          String       @db.VarChar(32)
  deliveryStatus   String       @default("pending") @map("delivery_status") @db.VarChar(32)
  providerResponse String?      @map("provider_response") @db.VarChar(1000)
  sentAt           DateTime?    @map("sent_at") @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  notification     Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_deliveries")
}

model Inquiry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId       String?   @map("listing_id") @db.Uuid
  projectId       String?   @map("project_id") @db.Uuid
  buyerUserId     String    @map("buyer_user_id") @db.Uuid
  recipientUserId String    @map("recipient_user_id") @db.Uuid
  chatId          String?   @unique @map("chat_id") @db.Uuid
  inquiryType     String    @default("general") @map("inquiry_type") @db.VarChar(32)
  firstMessage    String?   @map("first_message") @db.VarChar(2000)
  status          String    @default("open") @db.VarChar(32)
  respondedAt     DateTime? @map("responded_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  buyerUser       User      @relation("InquiryBuyer", fields: [buyerUserId], references: [id])
  chat            Chat?     @relation(fields: [chatId], references: [id])
  listing         Listing?  @relation(fields: [listingId], references: [id])
  project         Project?  @relation(fields: [projectId], references: [id])
