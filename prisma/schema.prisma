  name             String?   @db.VarChar(120)
  email            String?   @db.VarChar(255)
  phone            String?   @db.VarChar(32)
  subject          String?   @db.VarChar(180)
  message          String    @db.VarChar(3000)
  sourcePage       String?   @map("source_page") @db.VarChar(500)
  userId           String?   @map("user_id") @db.Uuid
  assignedToUserId String?   @map("assigned_to_user_id") @db.Uuid
  adminNotes       String?   @map("admin_notes") @db.VarChar(2000)
  metadataJson     Json?     @map("metadata_json")
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedToUser   User?     @relation("InboundSubmissionAssignee", fields: [assignedToUserId], references: [id])
  user             User?     @relation("InboundSubmissionUser", fields: [userId], references: [id])

  @@index([submissionType, status, createdAt])
  @@index([status, createdAt])
  @@index([email])
  @@index([userId])
  @@index([assignedToUserId])
  @@map("inbound_submissions")
}

model NewsletterSubscriber {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  name          String?   @db.VarChar(120)
  city          String?   @db.VarChar(120)
  interestsJson Json?     @map("interests_json")
  sourcePage    String?   @map("source_page") @db.VarChar(500)
  status        String    @default("active") @db.VarChar(32)
  confirmedAt   DateTime? @map("confirmed_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@index([city])
  @@map("newsletter_subscribers")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}
